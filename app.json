{
  "expo": {
    "name": "Black White Accounting",
    "slug": "flash-accounting",
    "version": "1.0.4",
    "orientation": "portrait",
    "scheme": "flashaccounting",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/icons/AppIcon.icon",
      "buildNumber": "11",
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "This app needs access to speech recognition to allow you to dictate expense descriptions.",
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to allow you to dictate expense descriptions.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.zii.flash.accounting"
    },
    "android": {
      "package": "com.zii.flash.accounting",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-sharing",
      "@sentry/react-native",
      "expo-sqlite",
      "expo-web-browser",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0e3f6692-c301-40ec-b891-456bf9fa0dd0"
      }
    }
  }
}
