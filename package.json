{
  "name": "flash-accounting",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo start --ios --localhost",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "build:ios:prod": "eas build --platform ios --profile production",
    "build:android:prod": "eas build --platform android --profile production",
    "submit:ios:prod": "eas submit --platform ios --profile production",
    "submit:android:prod": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@expo/material-symbols": "^0.1.1",
